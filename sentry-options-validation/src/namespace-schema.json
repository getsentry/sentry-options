{
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "type": {
      "const": "object"
    },
    "additionalProperties": {
      "type": "boolean"
    },
    "properties": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "type": "object",
          "properties": {
            "type": {
              "enum": ["string", "integer", "number", "boolean", "array", "object"]
            },
            "default": {},
            "description": {
              "type": "string"
            },
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "enum": ["string", "integer", "number", "boolean", "object"]
                },
                "properties": {
                  "$ref": "#/$defs/shape"
                }
              },
              "required": ["type"],
              "additionalProperties": false,
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "object"
                      }
                    }
                  },
                  "then": {
                    "required": ["properties"]
                  }
                }
              ]
            },
            "properties": {
              "$ref": "#/$defs/shape"
            }
          },
          "required": ["type", "default", "description"],
          "additionalProperties": false,
          "allOf": [
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "array"
                  }
                }
              },
              "then": {
                "required": ["items"]
              }
            },
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "object"
                  }
                }
              },
              "then": {
                "required": ["properties"]
              }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["version", "type", "properties"],
  "additionalProperties": false,
  "$defs": {
    "shape": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "type": "object",
          "properties": {
            "type": {
              "enum": ["string", "integer", "number", "boolean"]
            }
          },
          "required": ["type"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
